# LLM provider keys. Leave empty here; supply local values in your own .env file.
OPENROUTER_API_KEY=

# Search provider key. Leave empty here; never commit real API keys.
SERPER_API_KEY=

# Optional reranking or retrieval provider key. Leave empty here.
JINA_API_KEY=

# Optional local database password. Leave empty here; set a local value only if enabling Postgres.
POSTGRES_PASSWORD=

# Local runtime settings.
ROMA_RUNTIME__TIMEOUT=700

# Keep optional services disabled unless a local workflow explicitly needs them.
POSTGRES_ENABLED=false
MLFLOW_ENABLED=false

# Optional local storage root. Leave commented unless needed for local experiments.
# STORAGE_BASE_PATH=
