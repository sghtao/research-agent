# LLM
OPENROUTER_API_KEY=

# Search
SERPER_API_KEY=

# ODS (나중에)
JINA_API_KEY=

# Docker
POSTGRES_PASSWORD=roma_secret
ROMA_RUNTIME__TIMEOUT=700

# 로컬에서 도커 없이 `roma-dspy solve`만 돌릴 때 (DB·MLflow 컨테이너 없음)
POSTGRES_ENABLED=false
MLFLOW_ENABLED=false

# 파일 스토리지 루트 (미설정 시 crypto_agent는 ROMA 기준 .tmp/sentient). Docker에서 /opt 쓰면:
# STORAGE_BASE_PATH=/opt/sentient
